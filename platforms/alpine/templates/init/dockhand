#!/sbin/openrc-run

name="dockhand"
description="container - dockhand"

restart_command="/usr/bin/docker compose -f /opt/core/dockhand/compose.yaml restart"
start_command="/usr/bin/docker compose -f /opt/core/dockhand/compose.yaml up -d"
stop_command="/usr/bin/docker compose -f /opt/core/dockhand/compose.yaml down"
stop_command_args="--rmi all --volumes"

depend() {
        need docktail id
        use docker tailscale
}

start() {
        ebegin "STARTING - $name"
        sleep 15
        ${start_command}
        eend $?
}

stop() {
        ebegin "STOPPING - $name"
        ${stop_command} ${stop_command_args}
        eend $?
}

restart() {
        ebegin "RESTARTING - $name"
        ${restart_command}
        eend $?
}
