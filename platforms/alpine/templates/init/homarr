#!/sbin/openrc-run

name="homarr"
description="container - homarr"

down_command_args="--rmi all --volumes"
down_command="/usr/bin/docker compose -f /opt/core/homarr/compose.yaml down"
restart_command="/usr/bin/docker compose -f /opt/core/homarr/compose.yaml restart"
start_command="/usr/bin/docker compose -f /opt/core/homarr/compose.yaml up -d"
stop_command="/usr/bin/docker compose -f /opt/core/homarr/compose.yaml stop"

depend() {
        need docktail
        use docker tailscale
}

start() {
        ebegin "STARTING - $name"
        sleep 5
        ${start_command}
        eend $?
}

stop() {
        ebegin "STOPPING - $name"
        ${stop_command}
        eend $?
}

restart() {
        ebegin "RESTARTING - $name"
        ${restart_command}
        eend $?
}

down() {
        ebegin "DESTROYING - $name"
        ${down_command} ${down_command_args}
        eend $?
}
