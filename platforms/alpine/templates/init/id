#!/sbin/openrc-run

name="id"
description="container - id"

down_command_args="--rmi all --volumes"
down_command="/usr/bin/docker compose -f /opt/core/id/compose.yaml down"
restart_command="/usr/bin/docker compose -f /opt/core/id/compose.yaml restart"
start_command="/usr/bin/docker compose -f /opt/core/id/compose.yaml up -d"
stop_command="/usr/bin/docker compose -f /opt/core/id/compose.yaml stop"
upgrade_compose_command="curl -sL -o /opt/core/id/compose.yaml -H 'Cache-Control: no-cache, no-store' https://raw.githubusercontent.com/chadwagoner/GARAGELAB.launchpad/main/stacks/core/id/compose.yaml"

depend() {
        need docktail
        use docker tailscale
}

start() {
        ebegin "STARTING - $name"
        sleep 5
        ${start_command}
        eend $?
}

stop() {
        ebegin "STOPPING - $name"
        ${stop_command}
        eend $?
}

restart() {
        ebegin "RESTARTING - $name"
        ${restart_command}
        eend $?
}

upgrade() {
        ebegin "UPGRADING - $name"
        ${down_command} ${down_command_args}
        ${upgrade_compose_command}
        ${start_command}
        eend $?
}
