#!/bin/bash

### UPDATE CORE SERVICES
### DOCKTAIL
if [[ -n '$(docker container list --filter "name=^docktail$" --quiet)' ]]; then
  local_compose=$(cat /opt/core/docktail/compose.yaml | sha256sum | awk '{print $1}')
  remote_compose=$(curl -sL -H 'Cache-Control: no-cache, no-store' https://raw.githubusercontent.com/chadwagoner/GARAGELAB.launchpad/main/stacks/core/docktail/compose.yaml | sha256sum | awk '{print $1}')

  if [[ $local_compose != $remote_compose ]]; then
    rc-service docktail upgrade
    echo "SUCCESS: DOCKTAIL UPDATED..."
    sleep 10
  else
    echo "INFO: DOCKTAIL IS CURRENT... Skipping"
  fi
else
  echo "WARNING: DOCKTAIL DOES NOT EXIST... Skipping"
fi

